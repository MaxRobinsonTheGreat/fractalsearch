# Experiment progress IS version controlled so a clone can pick up where you left off:
#   - runs.jsonl            the run history / leaderboard
#   - runs/<id>/result.json that run's record
#   - runs/<id>/*.py        a snapshot of the solution source that produced it
# But the heavy, re-derivable artifacts stay local:
runs/**/*.pt
runs/**/*.png
run.log
dashboard.log

# Cached ground-truth eval fixtures
.cache/

# Python
__pycache__/
*.pyc
.venv/
.python-version.local

# uv
# (uv.lock IS committed, like autoresearch)
dashboard.log
